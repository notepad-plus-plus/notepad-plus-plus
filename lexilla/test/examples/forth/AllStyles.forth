\ SCE_FORTH_DEFAULT=0
    

\ SCE_FORTH_COMMENT=1
\ line comment

\ SCE_FORTH_COMMENT_ML=2
( stream comment )

\ SCE_FORTH_IDENTIFIER=3
FOO

\ SCE_FORTH_CONTROL=4
DO
LOOP

\ SCE_FORTH_KEYWORD=5
.S
2DUP
CR

\ SCE_FORTH_DEFWORD=6
: WORD ;

\ SCE_FORTH_PREWORD1=7
POSTPONE WORD

\ SCE_FORTH_PREWORD2=8
INCLUDE S" module.forth"

\ SCE_FORTH_NUMBER=9
$7F
%01111111
127

\ SCE_FORTH_STRING=10
." Hello, world."
ABORT" Aborting..."

\ SCE_FORTH_LOCALE=11
{ local-var }
